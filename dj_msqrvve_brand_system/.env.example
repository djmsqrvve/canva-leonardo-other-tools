# Leonardo production API (required for generate-api)
LEONARDO_API_KEY=

# Canva OAuth client (required to mint Canva access tokens and to refresh them later)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Canva access token (required for sync/autofill/export flows unless runtime can refresh it)
CANVA_ACCESS_TOKEN=
# Canva refresh token (optional, enables automatic access-token renewal)
CANVA_REFRESH_TOKEN=

# Optional Canva OAuth scope overrides
CANVA_SCOPES=
CANVA_INCLUDE_AUTOFILL_SCOPES=0

# Optional local browser override for generate-browser
CHROME_BINARY=
